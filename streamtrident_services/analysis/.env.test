# Test stack — isolated ports/volumes; does not replace production analysis.
# Split deploy: capture on 172.16.88.12 (ens35), analysis on this host.

COMPOSE_PROJECT_NAME=streamtrident-test

# Remote capture host (Redis + suricata-agent).
CAPTURE_REDIS_HOST=172.16.88.12
CAPTURE_REDIS_PORT=16379
TRIDENT_SURICATA_AGENT_URLS=http://172.16.88.12:19100
TRIDENT_SURICATA_AGENT_TOKEN=

TRIDENT_API_HOST_PORT=9090
POSTGRES_HOST_PORT=25432
CLICKHOUSE_HTTP_HOST_PORT=28123
CLICKHOUSE_NATIVE_HOST_PORT=29000
