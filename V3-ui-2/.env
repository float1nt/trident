# 复制为 .env 后按需修改：docker compose --env-file .env up -d

# 浏览器访问 UI 的宿主机端口
UI_HOST_PORT=8088

# 认证与业务 API：本机 analysis 测试栈（streamtrident_services/analysis/start-test.sh）
API_AUTH_UPSTREAM=http://host.docker.internal:9090
API_TRIDENT_UPSTREAM=http://host.docker.internal:9090

# 生产 analysis 栈（start.sh，默认 8090）：
# API_AUTH_UPSTREAM=http://host.docker.internal:8090
# API_TRIDENT_UPSTREAM=http://host.docker.internal:8090

# 远程联调机：
# API_AUTH_UPSTREAM=http://172.16.2.110:18090
# API_TRIDENT_UPSTREAM=http://172.16.2.110:18090
